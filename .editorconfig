# EditorConfig (https://editorconfig.org) — cross-editor baseline.
# See analysis/synthesis/items/ITM-008 for rationale.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.py]
indent_size = 4

[*.{yml,yaml,json,toml}]
indent_size = 2

[Makefile]
indent_style = tab

# Preserve Markdown hard breaks (`<two-spaces>\n`).
# Decided in round-2 Q&A; see analysis/synthesis/items/ITM-008-C04.
[*.md]
trim_trailing_whitespace = false
